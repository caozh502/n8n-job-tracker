# ========================================
# n8n Job Tracker — Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
# n8n uses $env.VAR_NAME in expressions.

# File access: allow Read/Write Files from Disk to read cv/ folder
N8N_RESTRICT_FILE_ACCESS_TO=./cv

# Scraper server port (default: 3456)
SCRAPER_PORT=3456

# Chrome path for Puppeteer (if needed)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# --- n8n Node Configuration (if using env vars instead of hardcoded) ---
# LinkedIn job search keywords
SEARCH_KEYWORDS=QA Engineer OR Test Automation OR CI/CD
# Search location
SEARCH_LOCATION=Munich, Germany

# --- Notion (set inside n8n credentials UI, not here) ---
# Database ID for job records
# NOTION_DATABASE_ID=39ee7030-f79a-8071-a8ef-dfa9a1ecba1a

# --- DeepSeek (set inside n8n credentials UI, not here) ---
# DEEPSEEK_API_KEY=sk-your-key-here
