    {
      "parameters": {
        "jsCode": "// Extract from File 输出文本在 $json.text 中\n// 不做复杂解析，直接输出纯文本作为 CV 信息\nconst rawText = $json.text || $json.data || '';\nif (!rawText) return [{ cvText: 'CV 读取失败，请确认 cv/CV.pdf 文件存在且可读' }];\n\n// 简单清理：去多余空白、截断过长的文本\nconst cleanText = rawText.replace(/\\s+/g, ' ').trim();\nconst maxLen = 30000;\nconst cvText = cleanText.length > maxLen ? cleanText.substring(0, maxLen) + '...' : cleanText;\n\nreturn [{ cvText: cvText }];"
      },
