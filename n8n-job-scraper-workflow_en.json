    {
      "parameters": {
        "jsCode": "// Extract from File outputs text in $json.text\n// No complex parsing, output raw text as CV info\nconst rawText = $json.text || $json.data || '';\nif (!rawText) return [{ cvText: 'CV read failed. Make sure cv/CV.pdf exists and is readable.' }];\n\n// Simple cleanup: remove extra whitespace, truncate long text\nconst cleanText = rawText.replace(/\\s+/g, ' ').trim();\nconst maxLen = 30000;\nconst cvText = cleanText.length > maxLen ? cleanText.substring(0, maxLen) + '...' : cleanText;\n\nreturn [{ cvText: cvText }];"
      },
      "id": "9154fa77-1870-49ad-86f3-e4a3f819661e",
      "name": "📄 Structure CV Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -90112,
        -2544
      ]
    },
    {
      "parameters": {
        "jsCode": "// Receive raw CV text from Extract from File\nconst rawText = $input.first().json.cvText || '';\n\nif (!rawText || rawText.trim().length < 20) {\n  return [{ prompt: 'CV text too short or empty', _meta: { warning: 'CV读取失败' } }];\n}\n\nconst prompt = `Summarize the following CV text into a structured format. Output as JSON only, no extra content.\n\n## 输出格式（严格 JSON）\n{\n  \"name\": \"Name (leave empty if not found)\",\n  \"education\": \"Highest degree + School + Major\",\n  \"status\": \"Current work status\",\n  \"experience_summary\": \"3-5 key experiences, one sentence each\",\n  \"key_skills\": \"Key skills, comma separated\",\n  \"certificates\": \"Certificates\",\n  \"languages\": \"Language proficiency\",\n  \"location\": \"Location\",\n  \"target_roles\": \"Target roles inferred from CV\",\n  \"years_of_experience\": \"Total years of experience (approx.)\"\n}\n\n## CV Text\n${rawText}`;\n\nreturn [{ prompt: prompt }];"
      },
      "id": "e134120b-8022-4dc8-97c2-2b0f54bf001f",
      "name": "✍️ Prepare CV Summary Prompt",
