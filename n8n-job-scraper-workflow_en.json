      },
      "id": "1e1f5a2d-3d9d-4ed4-aa08-d9b9bd9491bb",
      "name": "🧠 DeepSeek Chat Model (CV)",
      "type": "n8n-nodes-langchain.lmChatDeepSeek",
      "typeVersion": 1,
      "position": [
        -89712,
        -2352
      ],
      "credentials": {
        "deepSeekApi": {
          "id": "NXItNfVcOMfUJ3kd",
          "name": "DeepSeek account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// LLM Chain 输出在 $json.text 中\nconst raw = $json.text || $json.output || '';\nif (!raw) return [{ cvText: 'CV summary failed' }];\n\n// 尝试提取 JSON\nlet summary;\ntry { summary = JSON.parse(raw); }\ncatch(e) {\n  try { const m = raw.match(/\\{[\\s\\S]*\\}/); if (m) summary = JSON.parse(m[0]); }\n  catch(e2) { summary = { error: 'Parse failed', raw: raw.substring(0, 200) }; }\n}\n\n// 构建结构化的 CV 文本用于后续评分\nconst lines = [];\nif (summary.education) lines.push('- 学历: ' + summary.education);\nif (summary.status) lines.push('- 状态: ' + summary.status);\nif (summary.experience_summary) {\n  lines.push('- 经历:');\n  const exps = Array.isArray(summary.experience_summary) ? summary.experience_summary : [summary.experience_summary];\n  exps.forEach(e => lines.push('  - ' + e));\n}\nif (summary.key_skills) lines.push('- 技能: ' + summary.key_skills);\nif (summary.certificates) lines.push('- 证书: ' + summary.certificates);\nif (summary.languages) lines.push('- 语言: ' + summary.languages);\nif (summary.location) lines.push('- 地点: ' + summary.location);\nif (summary.target_roles) lines.push('- 目标岗位: ' + summary.target_roles);\nif (summary.years_of_experience) lines.push('- 经验: ' + summary.years_of_experience + '年');\n\nreturn [{ cvText: lines.join('\\n') }];"
      },
